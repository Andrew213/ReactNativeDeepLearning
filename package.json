    "babel-preset-expo": "^55.0.17",
    "clsx": "^2.1.1",
    "eslint-plugin-react-native": "^5.0.0",
    "expo": "~54.0.33",
    "expo-constants": "~18.0.13",
    "expo-font": "~14.0.11",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-linear-gradient": "~15.0.8",
    "expo-linking": "~8.0.11",
