{
  "extends": "expo/tsconfig.base",
  "compilerOptions": {
    "types": ["node"],
    "strict": true,
    "paths": {
      "@/*": ["./*"]
    }
  },
  "parserOptions": {
    "ecmaFeatures": {
      "jsx": true
    }
  },
  "include": [
    "**/*.ts",
    "**/*.tsx",
    ".expo/types/**/*.ts",
    "expo-env.d.ts",
    "nativewind-env.d.ts"
  ]
}
