{
  "expo": {
    "name": "ReactNativeDeepLearning",
    "slug": "ReactNativeDeepLearning",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "reactnativedeeplearning",
    "userInterfaceStyle": "automatic",
    "backgroundColor": "black",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.ReactNativeDeepLearning"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "expo-router"
      // [
      //   "expo-font",
      //   {
      //     "fonts": [
      //       "./assets/fonts/Sora-Medium.ttf",
      //       "./assets/fonts/Sora-Bold.ttf",
      //       "./assets/fonts/Sora-Light.ttf",
      //       "./assets/fonts/Sora-Regular.ttf",
      //       "./assets/fonts/Sekuya-Regular.ttf"
      //     ]
      //   }
      // ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
